# Server
PORT=5000
NODE_ENV=development

# MongoDB - paste your full connection string here
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/loopz?retryWrites=true&w=majority

# JWT Secret (generate a random string)
JWT_SECRET=replace_this_with_a_random_secret_key
JWT_EXPIRES_IN=30d

# Video storage — point this at your Railway volume mount path in production
# (e.g. /data). Locally it defaults to ./uploads next to server.js.
UPLOAD_DIR=/data

# Public base URL of this backend (no trailing slash). Used to build
# absolute video URLs returned to clients. If left blank, the URL is built
# from the incoming request — fine for most setups behind Railway's proxy.
# Example: https://loopz-api.up.railway.app
PUBLIC_URL=https://tiktokappbackend-production.up.railway.app

# CORS
CLIENT_URL=*
